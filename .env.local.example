NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
RESEND_API_KEY=re_your_key_here
NEXT_PUBLIC_ADMIN_EMAIL=franken_robin@hotmail.com

# Instance theme. Leave blank for the family/default (blue) variant.
# Set to "werk" on the work-only deployment to switch accents to green
# and rename the PWA to "WC 2026".
NEXT_PUBLIC_INSTANCE_THEME=

# Default UI language. Leave blank → "nl" (Dutch). Set to "en" for the
# work deployment so international colleagues land on English by default.
# Each user can still switch via the language picker in the profile menu.
NEXT_PUBLIC_DEFAULT_LANG=
